---
import { siteConfig } from '../config/site';
const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo Trans Express, saya ingin konsultasi import dari China.')}`;
---

<a
  href={wa}
  target="_blank"
  rel="noopener noreferrer"
  id="wafab"
  aria-label="Chat WhatsApp"
  class="fixed z-[120] bottom-4 right-4 md:bottom-6 md:right-6 inline-flex items-center gap-2.5 bg-[#1FAA5A] text-white font-display font-semibold rounded-[14px] pl-3 pr-4 py-3 shadow-[0_14px_34px_-12px_rgba(31,170,90,.8)] hover:bg-[#178a48] hover:-translate-y-0.5 transition-all duration-200"
>
  <span class="relative grid place-items-center w-7 h-7">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37s-1.04 1.02-1.04 2.48 1.07 2.88 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.89 9.88M20.46 3.49A11.82 11.82 0 0 0 12.05 0C5.5 0 .16 5.34.16 11.89c0 2.1.55 4.14 1.59 5.95L0 24l6.3-1.65a11.88 11.88 0 0 0 5.68 1.45h.01c6.55 0 11.89-5.34 11.89-11.89 0-3.18-1.24-6.16-3.42-8.42"/></svg>
    <span class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 rounded-full bg-orange-bright ring-2 ring-[#1FAA5A]"></span>
  </span>
  <span class="hidden sm:inline text-[0.92rem] leading-none">Chat WhatsApp</span>
</a>
