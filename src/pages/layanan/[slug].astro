---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import Faq from '../../components/Faq.astro';
import { siteConfig } from '../../config/site';
import { services, categoryLabel } from '../../data/services';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const s = service;
const related = services.filter((x) => x.category === s.category && x.slug !== s.slug).slice(0, 3);
const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent(`Halo Trans Express, saya ingin penawaran untuk layanan ${s.name}.`)}`;

const path = `/layanan/${s.slug}`;
const url = new URL(path, siteConfig.url).href;
const jsonld = [
  {
    '@type': 'Service',
    name: s.name,
    serviceType: s.group,
    description: s.tagline,
    url,
    provider: { '@id': `${siteConfig.url}/#organization` },
    areaServed: { '@type': 'Country', name: 'Indonesia' },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Beranda', item: siteConfig.url },
      { '@type': 'ListItem', position: 2, name: 'Layanan', item: `${siteConfig.url}/layanan` },
      { '@type': 'ListItem', position: 3, name: s.name, item: url },
    ],
  },
  {
    '@type': 'FAQPage',
    mainEntity: s.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
];
---

<BaseLayout title={s.meta.title} description={s.meta.description} keywords={s.meta.keywords} path={path} jsonld={jsonld} preload={s.image}>
  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <section class="pt-6 md:pt-10 pb-16 bg-paper px-4 md:px-8">
    <div class="max-w-[1360px] mx-auto">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-muted mb-8 fade-up">
        <a href="/" class="hover:text-orange transition-colors">Beranda</a><span aria-hidden="true">/</span>
        <a href="/layanan" class="hover:text-orange transition-colors">Layanan</a><span aria-hidden="true">/</span>
        <span class="text-ink font-medium">{s.name}</span>
      </nav>

      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-16 items-center">
        <div class="fade-up d1">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange/10 text-orange text-xs md:text-sm font-bold tracking-wider mb-6 uppercase">
            {categoryLabel[s.category]} · {s.group}
          </div>
          
          {s.imgIcon && (
            <div class="mb-4">
              <img src={s.imgIcon} alt={`Ikon layanan ${s.name}`} class="h-10 md:h-14 w-auto object-contain mix-blend-multiply" fetchpriority="high" width="120" height="56" />
            </div>
          )}
          
          <h1 class="font-display font-black leading-[1.05] text-ink text-[clamp(2.5rem,5.5vw,4.5rem)] tracking-tight mb-6">{s.name}</h1>
          <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl text-pretty">{s.intro}</p>

          <dl class="flex flex-wrap gap-x-8 gap-y-4 mt-8">
            {s.specs.map((sp) => (
              <div class="border-l-2 border-orange pl-4">
                <dt class="text-[0.72rem] uppercase tracking-[0.14em] text-muted mb-1">{sp.label}</dt>
                <dd class="font-display font-bold text-ink">{sp.value}</dd>
              </div>
            ))}
          </dl>

          <div class="flex flex-wrap gap-4 mt-10">
            <a href={wa} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--lg shadow-xl shadow-orange/30 group">
              Minta Penawaran
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/layanan" class="btn btn--ghost btn--lg">Semua Layanan</a>
          </div>
        </div>

        <div class="relative fade-up d2">
          <div class="rounded-[24px] overflow-hidden aspect-[4/3] md:h-[450px] lg:h-[550px] bg-sand border border-line shadow-2xl shadow-ink/5">
            <picture>
              <img src={s.image} alt={`Ilustrasi layanan ${s.name} pengiriman barang import`} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" fetchpriority="high" decoding="async" width="800" height="600" />
            </picture>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROSES (vertical timeline) ───────────────────────────────────── -->
  <section class="section">
    <div class="shell grid lg:grid-cols-[0.6fr_1.4fr] gap-10 lg:gap-16">
      <div class="fade-up">
        <p class="kicker mb-4">Cara kerja</p>
        <h2 class="h-xl balance">Alur Proses <span class="text-orange">{s.name}</span></h2>
      </div>
      <ol class="fade-up d1">
        {s.steps.map((st, i) => (
          <li class="grid grid-cols-[auto_1fr] gap-5 pb-8 last:pb-0 relative">
            {i < s.steps.length - 1 && <span class="absolute left-[1.4rem] top-12 bottom-0 w-px bg-line" aria-hidden="true"></span>}
            <span class="grid place-items-center w-11 h-11 rounded-full border border-line-2 font-display font-semibold text-ink bg-paper relative z-10">{i + 1}</span>
            <div class="pt-1.5">
              <h3 class="font-display font-semibold text-lg mb-1">{st.t}</h3>
              <p class="text-muted text-[0.95rem] leading-relaxed">{st.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ── KEUNGGULAN + KATEGORI ────────────────────────────────────────── -->
  <section class="section bg-sand">
    <div class="shell">
      <div class="grid lg:grid-cols-3 gap-x-10 gap-y-10">
        <div class="lg:col-span-1 fade-up">
          <p class="kicker mb-4">Keunggulan</p>
          <h2 class="h-xl balance">Kenapa memilih <span class="text-orange">{s.name}?</span></h2>
        </div>
        <ul class="lg:col-span-2 grid sm:grid-cols-2 gap-6 fade-up d1">
          {s.benefits.map((b) => (
            <li class="panel bg-paper p-8 rounded-[24px] shadow-sm border-none">
              <span class="grid place-items-center w-12 h-12 rounded-xl bg-orange/10 text-orange mb-5">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <h3 class="font-display font-bold text-xl text-ink mb-2">{b.t}</h3>
              <p class="text-muted text-[0.95rem] leading-relaxed">{b.d}</p>
            </li>
          ))}
        </ul>
      </div>

      {s.productCats && s.productCats.length > 0 && (
        <div class="mt-16 pt-12 border-t border-line fade-up">
          <p class="font-display font-medium text-muted text-sm uppercase tracking-wider mb-6">Cocok untuk berbagai jenis barang</p>
          <div class="flex flex-wrap gap-3">
            {s.productCats.map((c) => <span class="bg-paper border border-line rounded-full px-5 py-2.5 text-[0.95rem] text-ink-2 shadow-sm font-medium">{c}</span>)}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="shell grid lg:grid-cols-[0.7fr_1.3fr] gap-10 lg:gap-16">
      <div class="fade-up">
        <p class="kicker mb-4">FAQ</p>
        <h2 class="h-xl balance">FAQ Layanan <span class="text-orange">{s.name}</span></h2>
      </div>
      <div class="fade-up d1"><Faq items={s.faqs} /></div>
    </div>
  </section>

  <!-- ── RELATED ──────────────────────────────────────────────────────── -->
  {related.length > 0 && (
    <section class="section-sm bg-sand">
      <div class="shell">
        <p class="kicker mb-6">Layanan terkait</p>
        <div class="grid sm:grid-cols-3 gap-6">
          {related.map((r) => (
            <a href={`/layanan/${r.slug}`} class="panel bg-paper p-8 rounded-[24px] shadow-sm lift group border-none">
              <span class="grid place-items-center w-12 h-12 rounded-xl bg-sand-2 text-orange mb-5 group-hover:bg-orange group-hover:text-white transition-colors">
                {r.imgIcon ? (
                  <img src={r.imgIcon} alt={`Ikon layanan terkait ${r.name}`} class="w-8 h-8 object-contain drop-shadow-sm group-hover:brightness-0 group-hover:invert transition-all" loading="lazy" width="32" height="32" />
                ) : (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={r.icon}></svg>
                )}
              </span>
              <h3 class="font-display font-bold text-lg text-ink mb-2 group-hover:text-orange transition-colors">{r.name}</h3>
              <p class="text-muted text-[0.9rem] leading-relaxed">{r.tagline}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBand title={`Tertarik dengan ${s.name}?`} text="Kirim detail kebutuhan Anda lewat WhatsApp — kami bantu hitung estimasi dan urus prosesnya." />
</BaseLayout>
