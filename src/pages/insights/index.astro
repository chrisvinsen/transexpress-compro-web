---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { insights, insightCategories } from '../../data/insights';

const title = "Insights & Berita | Trans Express";
const description = "Temukan berbagai panduan import, berita logistik terbaru, dan tips bisnis dari Trans Express.";
---

<BaseLayout title={title} description={description} path="/insights">
  <!-- HERO -->
  <section class="pt-6 md:pt-10 pb-16 bg-paper px-4 md:px-8 border-b border-line">
    <div class="max-w-[1360px] mx-auto text-center fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange/10 text-orange text-xs md:text-sm font-bold tracking-wider mb-6 uppercase">
        Pusat Edukasi & Informasi
      </div>
      <h1 class="font-display font-black leading-[1.05] text-ink text-[clamp(2.5rem,5vw,4rem)] tracking-tight mb-6 max-w-4xl mx-auto">
        Insights & Berita <span class="text-orange">Terbaru</span>
      </h1>
      <p class="text-muted text-lg font-medium leading-relaxed max-w-2xl mx-auto">
        Kumpulan panduan import, update regulasi, dan strategi bisnis untuk membantu Anda mengambil keputusan logistik yang lebih baik.
      </p>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="section bg-sand relative z-10">
    <div class="shell max-w-[1360px] mx-auto">
      <!-- Categories Filter (Visual only for now) -->
      <div class="flex flex-wrap items-center justify-center gap-3 mb-12 fade-up">
        <span class="px-5 py-2.5 rounded-full bg-ink text-white font-medium text-[0.95rem] shadow-sm cursor-default">Semua</span>
        {insightCategories.map(cat => (
          <span class="px-5 py-2.5 rounded-full bg-paper border border-line text-ink-2 font-medium text-[0.95rem] hover:border-orange/50 hover:text-orange transition-colors cursor-default">{cat}</span>
        ))}
      </div>

      <!-- Articles Grid -->
      {insights.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {insights.map((article, i) => (
            <article class={`bg-paper rounded-[24px] border border-line overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 fade-up d${(i % 4) + 1} flex flex-col`}>
              <a href={`/insights/${article.slug}`} class="block relative aspect-[16/10] overflow-hidden bg-sand-2 group">
                <img 
                  src={article.image} 
                  alt={`Thumbnail artikel ${article.title}`} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                  loading="lazy" 
                  decoding="async" 
                  width="400"
                  height="250"
                />
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-ink tracking-wide uppercase">
                  {article.category}
                </div>
              </a>
              <div class="p-6 md:p-8 flex-1 flex flex-col">
                <time class="block text-[0.85rem] text-muted mb-3 font-medium">
                  {new Date(article.date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h2 class="font-display font-bold text-xl leading-tight mb-4 text-ink hover:text-orange transition-colors">
                  <a href={`/insights/${article.slug}`}>{article.title}</a>
                </h2>
                <p class="text-[0.95rem] text-muted leading-relaxed line-clamp-3 mb-6 flex-1">
                  {article.excerpt}
                </p>
                <div class="mt-auto pt-5 border-t border-line">
                  <a href={`/insights/${article.slug}`} class="inline-flex items-center gap-2 text-[0.9rem] font-bold text-ink-2 hover:text-orange group transition-colors">
                    Baca Selengkapnya
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="py-20 text-center max-w-lg mx-auto fade-up d1">
          <div class="w-20 h-20 bg-white border border-line rounded-full flex items-center justify-center mx-auto mb-6 text-muted">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          </div>
          <h3 class="font-display font-bold text-2xl text-ink mb-3">Belum Ada Artikel</h3>
          <p class="text-muted leading-relaxed">Saat ini kami sedang menyiapkan konten edukasi dan berita terbaru seputar logistik untuk Anda. Nantikan update selanjutnya!</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
