  <script>
    class ServiceSlider extends HTMLElement {
      connectedCallback() {
        const track = this.querySelector('#service-track');
        const prev = document.getElementById('slider-prev');
        const next = document.getElementById('slider-next');
        
        if(track && prev && next) {
          prev.addEventListener('click', () => {
            track.scrollBy({ left: -374, behavior: 'smooth' });
          });
          next.addEventListener('click', () => {
            track.scrollBy({ left: 374, behavior: 'smooth' });
          });

          // Grab to scroll logic
          let isDown = false;
          let isDragging = false;
          let startX;
          let scrollLeft;

          track.addEventListener('mousedown', (e) => {
            isDown = true;
            isDragging = false;
            track.classList.remove('snap-x', 'snap-mandatory');
            track.style.cursor = 'grabbing';
            startX = e.pageX - track.offsetLeft;
            scrollLeft = track.scrollLeft;
          });

          track.addEventListener('mouseleave', () => {
            if (!isDown) return;
            isDown = false;
            track.classList.add('snap-x', 'snap-mandatory');
            track.style.cursor = '';
          });

          track.addEventListener('mouseup', () => {
            isDown = false;
            track.classList.add('snap-x', 'snap-mandatory');
            track.style.cursor = '';
          });

          track.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - track.offsetLeft;
            const walk = (x - startX) * 1.5; // scroll-fast
            if (Math.abs(walk) > 5) isDragging = true;
            track.scrollLeft = scrollLeft - walk;
          });

          // Prevent link clicks if user was just dragging
          track.addEventListener('click', (e) => {
            if (isDragging) {
              e.preventDefault();
              e.stopPropagation();
              isDragging = false;
            }
          }, true);
        }
      }
    }
    customElements.define('service-slider', ServiceSlider);
  </script>

