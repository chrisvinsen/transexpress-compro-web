---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const values = [
  { t: 'Transparansi 100%', d: 'Biaya pengiriman dan pajak dihitung jelas di awal. Tidak ada tagihan siluman di akhir.' },
  { t: 'Tepat Waktu', d: 'Jadwal pengiriman yang konsisten agar perputaran stok bisnis Anda tetap lancar.' },
  { t: 'Aman & Terpercaya', d: 'Setiap pengiriman barang ditangani secara profesional. Bebas dari rasa khawatir karena barang Anda pasti sampai dengan selamat.' },
  { t: 'Layanan Lengkap', d: 'Dari pengiriman LCL/FCL hingga titip beli di 1688 dan Taobao, kami siap bantu segalanya.' },
];
const coverage = ['Guangzhou', 'Yiwu', 'Shenzhen', 'Jakarta', 'Surabaya', 'Medan', 'Bandung', 'Makassar'];
---

<BaseLayout
  title="Tentang Trans Express — Jasa Import China & Forwarder Terpercaya"
  description="Trans Express hadir untuk mempermudah bisnis impor Anda. Layanan import door-to-door yang praktis, aman, dan 100% transparan."
  keywords="jasa import china, forwarder china indonesia, import door to door, jasa titip beli china, pengiriman kargo china"
  path="/tentang"
  preload="/images/hero-containers.webp"
>
  <!-- Hero Section -->
  <section class="pt-6 md:pt-10 pb-16 bg-paper px-4 md:px-8">
    <div class="max-w-[1360px] mx-auto grid lg:grid-cols-[1.2fr_1fr] gap-8 lg:gap-16 items-center">
      <div class="fade-up text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange/10 text-orange text-xs md:text-sm font-bold tracking-wider mb-6 uppercase">
          <span class="w-2 h-2 rounded-full bg-orange animate-pulse"></span>
          Trans Express
        </div>
        <h1 class="font-display font-black leading-[1.05] text-ink text-[clamp(2.5rem,6vw,4.5rem)] tracking-tight mb-6">
          Tentang Kami
        </h1>
        <p class="text-muted text-lg md:text-xl font-medium leading-relaxed max-w-xl">
          Trans Express mengambil alih semua kerumitan impor Anda. Dari urusan pembayaran hingga proses clearance, semua kami tangani agar Anda bisa fokus pada bisnis.
        </p>
      </div>
      <div class="relative fade-up d1">
        <div class="rounded-[24px] overflow-hidden aspect-[4/3] md:aspect-auto md:h-[450px] lg:h-[550px] bg-sand border border-line">
          <img src="/images/hero-containers.webp" alt="Deretan kontainer kargo di pelabuhan untuk layanan import" class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" fetchpriority="high" decoding="async" width="800" height="600" />
        </div>
      </div>
    </div>
  </section>

  <!-- Mission split -->
  <section class="section bg-sand">
    <div class="shell grid lg:grid-cols-2 gap-6">
      <div class="panel bg-ink text-white p-8 md:p-12 relative overflow-hidden rounded-[24px] shadow-xl fade-up border-none">
        <span class="orbit" style="width:320px;height:320px;top:-160px;right:-100px;opacity:.6;" aria-hidden="true"></span>
        <p class="kicker text-orange-light mb-5">Visi Kami</p>
        <p class="h-lg text-white balance relative">Menjadi mitra logistik terpercaya yang menjembatani pebisnis Indonesia dengan potensi pasar China tanpa batas.</p>
      </div>
      <div class="panel bg-paper p-8 md:p-12 rounded-[24px] shadow-sm fade-up d1 border-line">
        <p class="kicker text-orange mb-5">Misi Kami</p>
        <ul class="space-y-6">
          <li class="flex gap-4 items-start"><span class="idx text-3xl text-sand-2 leading-none mt-1">01</span><p class="text-ink-2 font-medium text-lg leading-relaxed">Menyediakan layanan <em>door-to-door</em> yang praktis, dari penerimaan gudang hingga pengantaran.</p></li>
          <li class="flex gap-4 items-start"><span class="idx text-3xl text-sand-2 leading-none mt-1">02</span><p class="text-ink-2 font-medium text-lg leading-relaxed">Memberikan transparansi biaya mutlak, tanpa tagihan tersembunyi sedikit pun.</p></li>
          <li class="flex gap-4 items-start"><span class="idx text-3xl text-sand-2 leading-none mt-1">03</span><p class="text-ink-2 font-medium text-lg leading-relaxed">Menjamin keamanan maksimal untuk setiap kiriman hingga tiba di tangan Anda dengan selamat.</p></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-paper">
    <div class="shell">
      <div class="max-w-2xl mb-12 fade-up">
        <p class="kicker mb-4">Nilai Perusahaan</p>
        <h2 class="h-xl balance">Pilar Layanan <span class="text-orange">Trans Express</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((v, i) => (
          <div class="panel bg-sand-2 p-8 rounded-[24px] shadow-sm lift fade-up border-none" class:list={[`d${i + 1}`]}>
            <span class="idx text-4xl block mb-6 text-line-2">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="font-display font-bold text-xl mb-3 text-ink">{v.t}</h3>
            <p class="text-muted text-[0.95rem] leading-relaxed" set:html={v.d}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coverage -->
  <section class="section bg-sand">
    <div class="shell grid lg:grid-cols-[0.8fr_1.2fr] gap-10 lg:gap-16 items-center">
      <div class="fade-up">
        <p class="kicker mb-4">Jangkauan Luas</p>
        <h2 class="h-xl balance">Dari China ke <span class="text-orange">Seluruh Indonesia</span></h2>
        <p class="text-muted text-lg mt-5 leading-relaxed">Kami memiliki gudang konsolidasi sendiri di pusat industri seperti Guangzhou, Yiwu, dan Shenzhen. Barang Anda akan didistribusikan dengan aman ke berbagai kota di Indonesia.</p>
      </div>
      <div class="flex flex-wrap gap-3 fade-up d1">
        {coverage.map((c) => <span class="bg-paper border border-line rounded-full font-medium text-ink-2 px-5 py-3 shadow-sm hover:border-orange hover:text-orange transition-colors cursor-default">{c}</span>)}
        <span class="bg-orange/10 border border-orange text-orange font-bold rounded-full px-5 py-3 shadow-sm cursor-default">+ kota lainnya</span>
      </div>
    </div>
  </section>

  <CtaBand title="Mari bicara soal kebutuhan impor Anda." />
</BaseLayout>
