---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const num = siteConfig.contact.whatsapp.primary.number;
const wa = `https://wa.me/${num}?text=${encodeURIComponent('Halo Trans Express, saya ingin konsultasi.')}`;
const mapsLink = siteConfig.contact.address.gmaps;

const channels = [
  {
    label: 'WhatsApp',
    value: siteConfig.contact.whatsapp.primary.display,
    note: 'Respon tercepat pada jam kerja',
    href: wa, external: true,
    svg: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  },
  {
    label: 'Email',
    value: siteConfig.contact.email.cs,
    note: 'Untuk pertanyaan korporat / B2B',
    href: `mailto:${siteConfig.contact.email.cs}`, external: false,
    svg: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  },
  {
    label: 'Instagram',
    value: '@transexpress',
    note: 'Update & info terbaru',
    href: siteConfig.social.instagram, external: true,
    svg: '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  },
];
---

<BaseLayout
  title="Kontak Trans Express — Konsultasi Import China"
  description="Hubungi Trans Express via WhatsApp, email, atau Instagram. Konsultasikan kebutuhan import China Anda — tim kami siap membantu pada jam kerja."
  keywords="kontak trans express, konsultasi import china, hubungi forwarder china"
  path="/kontak"
>
  <!-- Hero Section -->
  <section class="pt-6 md:pt-10 pb-16 bg-paper px-4 md:px-8">
    <div class="max-w-[1360px] mx-auto text-center fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange/10 text-orange text-xs md:text-sm font-bold tracking-wider mb-6 uppercase">
        Hubungi Kami
      </div>
      <h1 class="font-display font-black leading-[1.05] text-ink text-[clamp(2.5rem,6vw,4.5rem)] tracking-tight mb-6">
        Hubungi <span class="text-orange">Trans Express</span>
      </h1>
      <p class="lede mt-5 max-w-2xl mx-auto">Punya pertanyaan soal tarif, jalur, atau prosesnya? Kirim pesan — kami bantu dari awal sampai barang tiba.</p>
    </div>
  </section>

  <section class="section">
    <div class="shell grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- channels -->
      <!-- channels -->
      <div class="fade-up space-y-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-1 gap-4">
          {channels.map((c) => (
            <a href={c.href} target={c.external ? '_blank' : undefined} rel={c.external ? 'noopener noreferrer' : undefined} class="panel bg-sand-2 p-6 rounded-[24px] flex items-center gap-5 group lift border-none">
              <span class="grid place-items-center w-14 h-14 rounded-xl bg-white shadow-sm text-orange shrink-0 group-hover:bg-orange group-hover:text-white transition-colors">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={c.svg}></svg>
              </span>
              <span class="min-w-0 flex-1">
                <span class="block text-[0.78rem] uppercase tracking-[0.14em] text-muted mb-1">{c.label}</span>
                <span class="block font-display font-bold text-lg text-ink group-hover:text-orange transition-colors break-all leading-tight">{c.value}</span>
                <span class="block text-[0.85rem] text-muted mt-1">{c.note}</span>
              </span>
            </a>
          ))}
        </div>

        <div class="panel bg-orange-light/50 border border-orange/10 p-8 rounded-[24px]">
          <p class="font-display font-bold text-lg text-ink mb-4">Jam Operasional</p>
          <dl class="text-[0.95rem] text-ink-2 space-y-2">
            <div class="flex justify-between items-center"><dt class="text-muted">Senin – Jumat</dt><dd class="font-bold">{siteConfig.contact.hours.weekday}</dd></div>
            <div class="flex justify-between items-center"><dt class="text-muted">Sabtu</dt><dd class="font-bold">{siteConfig.contact.hours.saturday}</dd></div>
            <div class="flex justify-between items-center"><dt class="text-muted">Minggu</dt><dd class="font-bold">{siteConfig.contact.hours.sunday}</dd></div>
          </dl>
          <a href={mapsLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-[0.9rem] font-display font-bold text-orange mt-6 group">
            Lihat lokasi di peta
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- form -->
      <div class="panel bg-paper p-8 md:p-10 rounded-[24px] shadow-xl border-none fade-up d1">
        <h2 class="h-lg font-display font-bold text-2xl mb-2">Kirim pesan</h2>
        <p class="text-muted text-[0.95rem] mb-8">Isi formulir, lalu pesan Anda akan dilanjutkan ke WhatsApp kami.</p>
        <form id="kontakForm" class="space-y-5" novalidate data-wa={num}>
          <div>
            <label for="f-nama" class="block text-sm font-medium text-ink-2 mb-2">Nama <span class="text-orange">*</span></label>
            <input id="f-nama" name="nama" type="text" required autocomplete="name" placeholder="Nama Anda" class="w-full bg-sand-2 border-none rounded-lg px-5 py-3.5 text-ink placeholder:text-muted/70 focus:bg-orange/5 focus:ring-2 focus:ring-orange/50 transition-all" />
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="f-wa" class="block text-sm font-medium text-ink-2 mb-2">No. WhatsApp <span class="text-orange">*</span></label>
              <input id="f-wa" name="wa" type="tel" required autocomplete="tel" placeholder="08xxxxxxxxxx" class="w-full bg-sand-2 border-none rounded-lg px-5 py-3.5 text-ink placeholder:text-muted/70 focus:bg-orange/5 focus:ring-2 focus:ring-orange/50 transition-all" />
            </div>
            <div>
              <label for="f-email" class="block text-sm font-medium text-ink-2 mb-2">Email</label>
              <input id="f-email" name="email" type="email" autocomplete="email" placeholder="email@domain.com" class="w-full bg-sand-2 border-none rounded-lg px-5 py-3.5 text-ink placeholder:text-muted/70 focus:bg-orange/5 focus:ring-2 focus:ring-orange/50 transition-all" />
            </div>
          </div>
          <div>
            <label for="f-pesan" class="block text-sm font-medium text-ink-2 mb-2">Detail kebutuhan <span class="text-orange">*</span></label>
            <textarea id="f-pesan" name="pesan" rows="4" required placeholder="Ceritakan barang yang ingin diimpor, asal & tujuan, atau pertanyaan Anda…" class="w-full bg-sand-2 border-none rounded-lg px-5 py-3.5 text-ink placeholder:text-muted/70 focus:bg-orange/5 focus:ring-2 focus:ring-orange/50 transition-all resize-none"></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--lg w-full shadow-xl shadow-orange/30 group mt-4">
            Kirim via WhatsApp
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <p class="text-xs text-muted text-center mt-4">Dengan mengirim, Anda setuju dihubungi oleh tim Trans Express.</p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const f = document.getElementById('kontakForm');
      if (!f) return;
      f.addEventListener('submit', (e) => {
        e.preventDefault();
        const num = f.getAttribute('data-wa');
        const get = (id) => (document.getElementById(id)?.value || '').trim();
        const nama = get('f-nama'), wa = get('f-wa'), email = get('f-email'), pesan = get('f-pesan');
        if (!nama || !wa || !pesan) { f.reportValidity(); return; }
        const lines = [
          '*Pesan dari website Trans Express*',
          '———',
          `Nama: ${nama}`,
          `WhatsApp: ${wa}`,
          email ? `Email: ${email}` : '',
          '———',
          'Pesan:',
          pesan,
        ].filter(Boolean);
        window.open(`https://wa.me/${num}?text=${encodeURIComponent(lines.join('\n'))}`, '_blank');
      });
    })();
  </script>
</BaseLayout>
